#PROMPT
_git_prompt=/usr/share/git-core/contrib/completion/git-prompt.sh
[ -f "$_git_prompt" ] && source "$_git_prompt"
GIT_PS1_SHOWDIRTYSTATE=1
GIT_PS1_SHOWUNTRACKEDFILES=1

_build_ps1() {
    local exit_code=$?  # Must be first
    local G='\[\e[1;32m\]' R='\[\e[0m\]' E='\[\e[1;31m\]'

    # Container (purple, only when set)
    local container=""
    [ -n "$CONTAINER_ID" ] && container="[${CONTAINER_ID}] "

    # Jobs (only shown when there is at least one)
    local running stopped jobs_str=""
    running=$(jobs -r -p | wc -l)
    stopped=$(jobs -s -p | wc -l)
    if [ "$running" -gt 0 ] || [ "$stopped" -gt 0 ]; then
        local inner=""
        [ "$running" -gt 0 ] && inner+="${running}r"
        [ "$stopped" -gt 0 ] && inner+="${stopped}s"
        jobs_str="{${inner}} "
    fi

    # Git
    local git=""
    declare -f __git_ps1 &>/dev/null && {
        local b; b=$(__git_ps1 "%s")
        [ -n "$b" ] && git=" (${b})"
    }

    # Exit code (only when non-zero)
    local exit_str=""
    [ "$exit_code" -ne 0 ] && exit_str="${E}${exit_code}${R} "

    PS1="${G}${jobs_str}${container}\u@\h \w${git} ${R}\n${exit_str}\$ "
}

PROMPT_COMMAND="_build_ps1${PROMPT_COMMAND:+; ${PROMPT_COMMAND}}"


# Rebuild PATH with correct ordering after system initialization.
# Ensures /usr/local/* comes before /usr/*, removes all duplicates (including
# trailing-slash variants), and keeps any extra dirs (e.g. shelltape/bin).
#
# Root cause of old bug: `for dir in $PATH` with default IFS never splits on
# colons, so $PATH was treated as one big word and re-appended wholesale.
# Fix: set IFS=: when iterating, and use a three-pass strategy.
rebuild_path() {
    local new_path="" seen="" dir

    # Append dir to new_path only if it exists on disk and hasn't been seen yet.
    # Strips trailing slashes before comparing so /foo/ and /foo are treated equal.
    _path_add() {
        local d="${1%/}"                              # normalize trailing slash
        [ -d "$d" ] || return                         # skip non-existent dirs
        [[ ":$seen:" == *":$d:"* ]] && return         # skip duplicates
        new_path="${new_path:+$new_path:}$d"
        seen="${seen:+$seen:}$d"
    }

    # Pass 1 — user home dirs first, preserving their original relative order
    local IFS=:
    for dir in $PATH; do
        dir="${dir%/}"
        [[ "$dir" == "$HOME"* ]] && _path_add "$dir"
    done

    # Pass 2 — known system dirs in explicit priority order
    _path_add /usr/local/sbin
    _path_add /usr/local/bin
    _path_add /usr/sbin
    _path_add /usr/bin
    _path_add /usr/lib64/ccache
    _path_add /sbin
    _path_add /bin

    # Pass 3 — anything else not yet captured (custom tools, future additions)
    for dir in $PATH; do
        _path_add "$dir"
    done

    PATH="$new_path"
    unset -f _path_add
}
rebuild_path
export PATH


