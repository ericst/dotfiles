# tmux configuration

# Set prefix key to M-Space
unbind C-b
set -g prefix M-Space
bind M-Space send-prefix

# Start pane numbering at 1 instead of 0
set -g base-index 1
setw -g pane-base-index 1

# Move status bar to the top
set -g status-position top

# Pane navigation keybindings
# Use M-Space + h/j/k/l for pane navigation
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# Use M-Space + o to switch between panes (cycle through panes)
bind o select-pane -t :.+

# Pane creation keybindings
# Use M-Space + s for new split below (horizontal split)
bind s split-window -v

# Use M-Space + v for new split to the right (vertical split)
bind v split-window -h

# Use M-Space + f to toggle pane zoom
bind f resize-pane -Z

# Use M-Space + c to close pane
bind c kill-pane

# Use M-Space + n to create a new pane
bind n new-window

# Additional useful configurations
# Enable mouse support for pane selection and resizing
set -g mouse on

# Set default terminal to tmux-256color (modern, correct value for tmux sessions)
set -g default-terminal "tmux-256color"

# Enable focus events for applications that need them
set -g focus-events on

# Enable extended key reporting and forward to inner apps that request it (tmux 3.5+).
# extended-keys-format csi-u: use CSI-u encoding (\e[13;2u for Shift+Enter, etc.),
# which is what pi and neovim expect.
#
# NOTE: 'terminal-features xterm*:extkeys' is intentionally NOT set here.
# Ghostty's terminfo does NOT declare extkeys support — forcing it would make tmux
# send \e[>4;1m to Ghostty, putting it in extended-key mode and corrupting bracketed
# paste (newlines become \e[13;1u CSI sequences inside paste events).
# Ghostty already emits extended key sequences natively without being asked,
# so tmux receives them and forwards them to inner apps correctly without any override.
set -g extended-keys on
set -g extended-keys-format csi-u

# Enable true color (RGB) for xterm-compatible terminals (Ghostty uses xterm-256color)
set -as terminal-overrides ',xterm-256color:RGB'

# Set escape-time to 25ms for responsive Esc and Alt key handling
# This fixes issues where Esc and Alt+key combinations are delayed or require
# additional keypresses to register in nested terminal environments (tmux inside ghostty)
set -g escape-time 25

# Set history limit
set -g history-limit 100000

# Status bar customization with purple color to match terminal prompt
set -g status-style bg=color56,fg=white
